{
  "productName": "2syn_Client",
  "version": "3.6.3",
  "identifier": "com.twosyn.app",
  "build": {
    "frontendDist": "../dist",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "2syn Client",
        "visible": true,
        "devtools": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons-client/32x32.png",
      "icons-client/128x128.png",
      "icons-client/128x128@2x.png",
      "icons-client/icon.icns",
      "icons-client/icon.ico"
    ],
    "iOS": {
      "developmentTeam": "6UJ8GS752W",
      "minimumSystemVersion": "15.0",
      "infoPlist": "Info.ios.plist"
    }
  }
}
